# Client analytics + error monitoring (slice #10, ADR D-008).
#
# All keys are `PUBLIC_*` — Astro inlines them into the CLIENT bundle at build
# time, so they are NOT secrets (Firebase web config and the Sentry DSN are safe
# to expose). Leaving any group unset simply turns that SDK OFF — the site builds
# and runs green without them.
#
# Two environments (D-002/D-020), two files — both git-ignored, copy from here:
#   .env       → local dev + `deploy:stage`   (project: solar-time-stage)
#   .env.prod  → `deploy:prod` only           (project: solar-time-prod)
# `.env` is auto-loaded by every Astro build; `.env.prod` is loaded ONLY by
# `deploy:prod` (via dotenv-cli), and its values take precedence — so stage/dev
# builds never pick up prod keys. The Sentry `environment` tag is derived from
# `SITE_ENV`, not set here (staging by default, production for `deploy:prod`).

# --- Firebase Analytics (cookieless) ---
# Firebase console → Project settings → your web app config (or
# `firebase apps:sdkconfig WEB <appId> --project <project>`). API_KEY/PROJECT_ID/
# APP_ID are required; AUTH_DOMAIN is optional. MEASUREMENT_ID (G-…) appears only
# once Google Analytics is linked to the project (console → Integrations) and is
# REQUIRED for analytics to boot — without it, analytics stays off.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
PUBLIC_FIREBASE_AUTH_DOMAIN=

# --- Sentry (error-only) ---
# Sentry → Project → Settings → Client Keys (DSN). One DSN covers both envs.
PUBLIC_SENTRY_DSN=
