# Client analytics + error monitoring (slice #10, ADR D-008).
#
# Copy to `.env` and fill in per environment. All keys are `PUBLIC_*` — Astro
# inlines them into the CLIENT bundle at build time, so they are NOT secrets
# (Firebase web config and the Sentry DSN are safe to expose). Leaving any group
# unset simply turns that SDK OFF — the site builds and runs green without them.
#
# The Sentry `environment` tag is NOT set here: it is derived at build time from
# `SITE_ENV` (staging by default, production for `deploy:prod`) — see src/config/site.ts.

# --- Firebase Analytics (cookieless) ---
# From the Firebase console → Project settings → your web app config. All four
# are required for Analytics to boot; AUTH_DOMAIN is optional.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
PUBLIC_FIREBASE_AUTH_DOMAIN=

# --- Sentry (error-only) ---
# From Sentry → Project → Settings → Client Keys (DSN).
PUBLIC_SENTRY_DSN=
