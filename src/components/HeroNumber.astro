---
/**
 * HeroNumber — the headline answer: the signed deviation (or "In sync"),
 * a one-line explanation, and the real solar-noon time.
 *
 * Presentational only. Values come from the view model; `data-*` hooks let the
 * client recompute patch them in place without a re-render.
 */
interface Props {
  heroValue: string;
  showUnit: boolean;
  leadText: string;
  solarNoonText: string;
  /**
   * Heading level for the number. `/[city]` keeps the default `h1` — there the
   * number *is* the page title. The landing (`/`, #82) passes `p`: its editorial
   * `<h1>` is the page's single heading, so the number must not emit one too.
   */
  as?: 'h1' | 'p';
  /**
   * Play the one-time "sunrise" entrance (rise + fade, #84). Default `true` for
   * `/[city]`, where the SSR value is stable and *is* the real answer. The
   * landing (`/`) passes `false`: its SSR number is the misleading Neutral
   * default (D-029), so animating it in would be a lie — and it is the LCP
   * element, so a fade-in would also delay paint. On `/` the meaningful motion
   * is the value crossfade when the resolved value lands (index.astro).
   */
  entrance?: boolean;
}
const { heroValue, showUnit, leadText, solarNoonText, as = 'h1', entrance = true } = Astro.props;
const Tag = as;
---

<div class="hero-block">
  <Tag class="hero" class:list={[{ synced: !showUnit, entrance }]}>
    <span data-hero-value>{heroValue}</span><span class="unit" data-hero-unit hidden={!showUnit}
      >min</span
    >
  </Tag>
  <p class="lead" data-lead>{leadText}</p>
  <p class="solar-noon" data-solar-noon>{solarNoonText}</p>
</div>

<style>
  .hero-block {
    text-align: center;
  }
  .hero {
    font-family: var(--mono);
    font-weight: 600;
    font-size: clamp(56px, 17vw, 104px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
  /* Sunrise entrance — opted in per page (see the `entrance` prop). transform +
     opacity only (no reflow); the shared motion tokens keep it in one language
     with the crossfade + pulse. prefers-reduced-motion disables it (tokens.css). */
  .hero.entrance {
    animation: rise var(--motion-base) var(--ease-out) both;
  }
  .hero.synced {
    font-size: clamp(32px, 9vw, 52px);
  }
  .unit {
    font-size: 0.34em;
    color: var(--muted);
    letter-spacing: 0;
    margin-left: 0.15em;
  }
  .lead {
    font-size: 16px;
    line-height: 1.5;
    color: var(--text);
    max-width: 40ch;
    margin: 20px auto 0;
    text-wrap: balance;
  }
  .solar-noon {
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted);
    margin: 6px auto 0;
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
