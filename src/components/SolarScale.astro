---
/**
 * SolarScale — horizontal time-of-day axis with the solar-noon marker.
 *
 * The inner SVG is built by `scaleInnerSvg` (shared with the client recompute)
 * and injected raw, so build and client draw identical geometry. The root SVG
 * keeps a fixed viewBox → no layout shift when the client repaints it.
 */
import type { ScaleGeometry } from '../lib/scaleGeometry';
import { scaleInnerSvg } from '../lib/scaleSvg';

interface Props {
  geometry: ScaleGeometry;
  solarNoonLabel: string;
}
const { geometry, solarNoonLabel } = Astro.props;
---

<div class="scale">
  <svg
    data-scale
    viewBox={`0 0 ${geometry.width} ${geometry.height}`}
    role="img"
    aria-label={`Solar noon at ${solarNoonLabel}, ideal noon at 12:00`}
    set:html={scaleInnerSvg(geometry)}
  />
  <div class="caption">
    <span>Clock noon</span>
    <span>Solar noon&nbsp;<span data-scale-noon>{solarNoonLabel}</span></span>
  </div>
</div>

<style>
  .scale {
    margin: clamp(28px, 8vw, 44px) 0 8px;
  }
  .scale svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .caption {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-dim);
    margin-top: 6px;
  }
  /* Narrow: the two ends can meet — drop the tracking so they never touch. */
  @media (max-width: 480px) {
    .caption {
      letter-spacing: 0.02em;
    }
  }
</style>

<style is:global>
  /*
   * Solar-noon marker: a single gentle breathe on appear (anim 2, #84). The dot
   * is injected via `set:html` (scaleInnerSvg, src/lib — untouched), so Astro's
   * scoped styles can't reach it. Target it globally through the unique
   * [data-scale] hook and the accent fill it always carries. It re-runs each
   * time the SVG is re-injected on a recompute (a fresh "appear") — never an
   * infinite loop, so no visual noise or battery drain. `transform-box: fill-box`
   * pivots the scale on the circle's own centre → zero position shift; only
   * `transform` animates. prefers-reduced-motion disables it (tokens.css).
   */
  [data-scale] circle[style*='fill:var(--accent)'] {
    transform-box: fill-box;
    transform-origin: center;
    animation: noon-pulse var(--motion-pulse) var(--ease-out) both;
  }
  @keyframes noon-pulse {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.16);
    }
    100% {
      transform: scale(1);
    }
  }
</style>
