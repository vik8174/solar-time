---
/**
 * Home (`/`) — the indexable landing (#82, amends D-005).
 *
 * Layout follows the interactive-tool-landing pattern (#82 research: time.is,
 * epochconverter): the **Live-geo tool** is the visual hero, first under the
 * shared header (which carries the brand + tagline, `Base.astro`). The crawlable
 * editorial content sits *below* it — the **explainer** (whose `<h1>` "What is
 * solar time?" is the page's single, keyword-bearing heading), the **City
 * directory**, and the **FAQ** — fully visible, just lower in the DOM, which
 * carries full SEO weight without a wall of text over the number. Heading size
 * is not a ranking factor, so the number stays hero.
 *
 * The tool (slice #7) server-renders a *Neutral default* (the largest city,
 * labelled an estimate so it never reads as the visitor's own value) that a
 * client island then, in order: (1) recomputes for *today* from inlined `data-*`
 * inputs (D-013 — no network, the guaranteed old-browser fallback); (2) upgrades
 * to the visitor's timezone estimate via `/tz-index.json` + `/geo-index.json`;
 * (3) on "📍" refines to an exact fix via the Geolocation API. All compute goes
 * through the same `computeDeviation` → `buildCityViewModel` SSOT as the city
 * pages (R-001).
 *
 * `/` is indexable on prod, `noindex` on stage (`noindex={!IS_PROD}`, like the
 * city pages, D-020). The live number is explicitly *not* the indexed content.
 */
import Breakdown from '../components/Breakdown.astro';
import HeroNumber from '../components/HeroNumber.astro';
import SolarScale from '../components/SolarScale.astro';
import { IS_PROD } from '../config/site';
import { CITIES } from '../data/cities';
import { computeDeviation } from '../domain/solarTime';
import Base from '../layouts/Base.astro';
import { buildCityViewModel } from '../lib/cityViewModel';
import { faqJsonLd, homeJsonLd, type FaqItem, type JsonLdNode } from '../lib/jsonLd';

// Title + description are consts so the JSON-LD below describes exactly what
// the `<head>` renders — schema that drifts from the page is spam (#86). The
// `<title>` stays brand-led; the `<h1>` (below) leads with the keyword phrase.
const TITLE = 'Solar Drift — how far your clock is from the sun';
const DESCRIPTION =
  'See how far your clock runs from true solar time, live for your location — the exact minutes, real solar noon, and the longitude, equation-of-time, and daylight-saving breakdown.';

// The Landing FAQ — the SSOT for both the visible copy and the `FAQPage`
// JSON-LD, so the structured data matches the page verbatim (D-025). Grounded
// in the site's own physics (the per-city prose + the deviation breakdown),
// nothing invented; kept editorially distinct from the per-city sentences.
// ("What is solar time?" is the explainer `<h1>` above, so it is not repeated
// here.) Google removed FAQ rich results (2026-05-07); this is for topical
// understanding, not a SERP snippet.
const FAQ_ITEMS: readonly FaqItem[] = [
  {
    question: 'Why is my clock ahead of or behind the sun?',
    answer:
      'Two steady reasons and one seasonal one. Your city usually sits east or west of the meridian its time zone is centred on, which shifts solar noon earlier or later; the Sun runs a little fast or slow through the year (the equation of time); and daylight-saving time adds an hour on top. Added together, they set how far your clock drifts from the sun.',
  },
  {
    question: 'What is the equation of time?',
    answer:
      "The equation of time is the gap — up to about 16 minutes either way — between clock-even mean solar time and the true Sun, caused by Earth's tilted axis and its elliptical orbit. It is why solar noon wanders across the year even for a city sitting right on its meridian, and why a sundial can read ahead of or behind the clock depending on the date.",
  },
];

// WebSite + WebApplication (#86) + the FAQPage that verbatim-mirrors FAQ_ITEMS
// (closes the #82 debt, D-025). `/` is indexable on prod, so crawlers read these.
const jsonLd = (origin: string): readonly JsonLdNode[] => [
  ...homeJsonLd({ origin, name: 'Solar Drift', description: DESCRIPTION }),
  faqJsonLd(FAQ_ITEMS),
];

// One population-desc sort (slug tie-break) is the SSOT for two things: its head
// is the Neutral default for first paint, and its top 24 are the City directory.
const byPopulation = [...CITIES].sort(
  (a, b) => b.population - a.population || (a.slug < b.slug ? -1 : 1),
);
const neutral = byPopulation[0];
if (!neutral) throw new Error('city registry is empty — cannot render the home default');
// Top 24 by population: a flat crawlable hub of the biggest cities (#82),
// distinct from #87's per-city same-timezone "related cities".
const directory = byPopulation.slice(0, 24);

const deviation = computeDeviation({
  longitude: neutral.longitude,
  timeZone: neutral.timeZone,
  date: new Date(),
});
const vm = buildCityViewModel({ name: neutral.name, coords: neutral.coords }, deviation);
---

<Base
  title={TITLE}
  description={DESCRIPTION}
  canonicalPath="/"
  ogImagePath="/og/home.png"
  noindex={!IS_PROD}
  support
  jsonLd={jsonLd}
>
  <main class="page" data-home-longitude={neutral.longitude} data-home-timezone={neutral.timeZone}>
    <div class="content">
      <section class="tool" aria-label="Solar time for your location">
        {
          /* The resolved-value region — the eyebrow + number + scale + breakdown
            all repaint together (SSG default → timezone estimate → 📍 fix), so
            they crossfade as one unit (anim 3, #84). The 📍 control below stays
            outside so it never fades mid-interaction. */
        }
        <div class="result" data-result>
          <p class="eyebrow">
            <span data-eyebrow-primary>{vm.cityName}</span>
            <span class="eyebrow-note" data-eyebrow-note>Estimated for your region</span>
          </p>

          <HeroNumber
            as="p"
            entrance={false}
            heroValue={vm.heroValue}
            showUnit={vm.showUnit}
            leadText={vm.leadText}
            solarNoonText={vm.solarNoonText}
          />

          <SolarScale geometry={vm.geometry} solarNoonLabel={vm.solarNoonLabel} />

          <Breakdown rows={vm.breakdown} />
        </div>

        <div class="geo">
          <button type="button" class="geo-button" data-geo-button>📍 Use my location</button>
          <p class="geo-hint" data-geo-hint hidden></p>
          <p class="geo-note">
            Calculated in your browser — your location never leaves it.{' '}
            <a href="/privacy">Privacy</a>
          </p>
        </div>
      </section>

      <section class="explainer" aria-labelledby="explainer-heading">
        <h1 id="explainer-heading">What is solar time?</h1>
        <p class="intro">
          Solar time is the time told by the Sun's real position in the sky. Its anchor is solar
          noon — the moment the Sun is due south and at its highest. Your clock instead follows a
          fixed time-zone offset, so the two rarely line up exactly. The number above is that gap,
          live for wherever you are, split into longitude, the equation of time, and daylight
          saving.
        </p>
      </section>

      <section class="directory" aria-labelledby="directory-heading">
        <h2 id="directory-heading">Solar time by city</h2>
        <p class="section-lead">
          The gap between clock and sun for some of the world's largest cities.
        </p>
        <ul class="directory-grid">
          {
            directory.map((city) => (
              <li>
                <a href={`/${city.slug}`} data-astro-prefetch>
                  {city.name}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Questions &amp; answers</h2>
        <dl class="faq-list">
          {
            FAQ_ITEMS.map((item) => (
              <div class="faq-item">
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))
          }
        </dl>
      </section>
    </div>
  </main>

  <script>
    import { trackEvent } from '../lib/analytics';
    import { computeDeviation } from '../domain/solarTime';
    import { buildCityViewModel } from '../lib/cityViewModel';
    import { findNearestCity } from '../lib/findNearestCity';
    import type { GeoCity } from '../lib/geoIndex';
    import {
      checkPermission,
      DEFAULT_TIMEOUT_MS,
      getCurrentPosition,
      GeolocationError,
    } from '../lib/geolocation';
    import { geoReducer, initialGeoState, type GeoEvent, type GeoState } from '../lib/geoReducer';
    import { geoStatusHint, locatedLabel } from '../lib/homeView';
    import { resolveDefaultCity, type ZoneCity } from '../lib/resolveDefaultCity';
    import { scaleInnerSvg } from '../lib/scaleSvg';

    /**
     * Home geo island (#126) — recompute + timezone-estimate + 📍, re-runnable
     * on every navigation. Registered on `astro:page-load` (below) because
     * `<main>` is swapped (not persisted) on every View-Transition nav, so on
     * Back/Forward to `/` the SSR *Neutral default* ("In sync") would otherwise
     * stick — the module `<script>` runs only once per full load. Twin of
     * `[city].astro`'s `initShare`: re-query the DOM and re-declare the mutable
     * state (`geoIndex`, reducer `state`) *inside* so each navigation starts on
     * the fresh nodes with clean state, and the fresh button gets the listener
     * (the detached one is GC'd — no leak, no stacking).
     */
    const initHome = (): void => {
      const root = document.querySelector<HTMLElement>('[data-home-longitude]');
      const button = document.querySelector<HTMLButtonElement>('[data-geo-button]');
      const hint = document.querySelector<HTMLElement>('[data-geo-hint]');
      if (!root || !button || !hint) return;

      // Value crossfade (anim 3, #84). The paint below swaps the number/breakdown/
      // labels in place; wrapping the swap in a quick fade-out → mutate → fade-in
      // turns the SSG→estimate→📍 jump into a calm crossfade (and smooths the
      // recompute jank). The fade itself is a CSS transition on [data-result]
      // (tokens.css → reduced-motion neutralises it), but the timing is JS, so we
      // ALSO honour prefers-reduced-motion here: matched → mutate instantly, no
      // setTimeout. Two layers, per the #84 brief. `--motion-fast` is the SSOT for
      // the duration — read it so the JS half-fade matches the CSS transition.
      const result = root.querySelector<HTMLElement>('[data-result]');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const fadeMs =
        parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--motion-fast')) ||
        180;
      let fadeTimer: ReturnType<typeof setTimeout> | undefined;
      const crossfade = (mutate: () => void): void => {
        if (!result || reducedMotion.matches) {
          mutate();
          return;
        }
        result.classList.add('is-swapping');
        // A newer swap supersedes a pending one: clear the in-flight timer so a
        // stale paint (e.g. the tz-estimate fade still pending when 📍 fires)
        // can't land after the state moved on — the fade-out just carries into
        // the newer value.
        if (fadeTimer !== undefined) clearTimeout(fadeTimer);
        fadeTimer = setTimeout(() => {
          fadeTimer = undefined;
          // A throwing paint (computeDeviation / buildCityViewModel / scaleInnerSvg
          // on some edge input) must never leave the region stuck invisible —
          // remove the class in `finally`, mirroring the default-recompute guard.
          try {
            mutate();
          } catch (error) {
            console.warn('home: crossfade paint failed', error);
          } finally {
            result.classList.remove('is-swapping');
          }
        }, fadeMs);
      };

      const browserTimeZone = (): string => Intl.DateTimeFormat().resolvedOptions().timeZone;
      let geoIndex: readonly GeoCity[] | null = null;
      let state: GeoState = initialGeoState;

      // All DOM writes query relative to *this invocation's* `root`, never the
      // global `document` — so if a slower async continuation (the tz/geo fetch
      // below) resolves after the visitor has navigated away and back, its
      // `root` is a detached `<main>` and every write lands on dead nodes
      // instead of clobbering the fresh page's hero (#126 re-entrancy guard;
      // the twin `initShare` gets this for free via closure-captured elements).
      const setText = (selector: string, text: string): void => {
        const el = root.querySelector(selector);
        if (el) el.textContent = text;
      };

      // Paints a view model into the hero / scale / breakdown — the R-001 render
      // glue, twin of the recompute in [city].astro (same SSOT compute path).
      const paint = (model: ReturnType<typeof buildCityViewModel>): void => {
        setText('[data-hero-value]', model.heroValue);
        setText('[data-lead]', model.leadText);
        setText('[data-solar-noon]', model.solarNoonText);
        setText('[data-scale-noon]', model.solarNoonLabel);
        const unit = root.querySelector<HTMLElement>('[data-hero-unit]');
        if (unit) unit.hidden = !model.showUnit;
        root.querySelector('.hero')?.classList.toggle('synced', model.inSync);
        const scale = root.querySelector('[data-scale]');
        if (scale) scale.innerHTML = scaleInnerSvg(model.geometry);
        for (const r of model.breakdown) {
          setText(`[data-row-value="${r.key}"]`, r.value);
          root.querySelector(`[data-row="${r.key}"]`)?.classList.toggle('zero', r.zero);
        }
      };

      const setEyebrow = (primary: string, note: string): void => {
        setText('[data-eyebrow-primary]', primary);
        const noteEl = root.querySelector<HTMLElement>('[data-eyebrow-note]');
        if (noteEl) {
          noteEl.textContent = note;
          // Hide the line entirely when empty, so it reserves no vertical space.
          noteEl.hidden = note === '';
        }
      };

      // Computes + paints the deviation for a longitude in a time zone.
      const render = (longitude: number, timeZone: string): void => {
        paint(
          buildCityViewModel(
            { name: '', coords: '' },
            computeDeviation({ longitude, timeZone, date: new Date() }),
          ),
        );
      };

      // Reflects the reducer state onto the button + hint (never the result).
      const renderControls = (): void => {
        const message = geoStatusHint(state.status);
        hint.hidden = message === null;
        if (message !== null) hint.textContent = message;
        // Denied / unsupported turn 📍 into the hint (not a dead button).
        button.hidden = state.status === 'denied' || state.status === 'unsupported';
        button.disabled = state.status === 'locating';
        button.textContent = state.status === 'locating' ? '📍 Locating…' : '📍 Use my location';
      };

      const dispatch = (event: GeoEvent): void => {
        state = geoReducer(state, event);
        renderControls();
      };

      // 1. Recompute the baked default for *today* — the guaranteed path that
      // needs no network and no Geolocation; if it throws (e.g. no Intl), the
      // server-rendered snapshot simply stays.
      const longitude = Number(root.dataset.homeLongitude);
      const timeZone = root.dataset.homeTimezone;
      try {
        if (timeZone && !Number.isNaN(longitude)) render(longitude, timeZone);
      } catch (error) {
        console.warn('home: default recompute failed', error);
      }

      // Old browser without Geolocation → mark unsupported (hides 📍, shows hint).
      if (!('geolocation' in navigator)) dispatch({ type: 'UNSUPPORTED' });

      const fetchJson = async (url: string): Promise<unknown> => {
        const response = await fetch(url);
        if (!response.ok) throw new Error(`${url} → ${String(response.status)}`);
        return response.json();
      };

      // 2. Upgrade to the visitor's timezone estimate + prime the geo index.
      void (async (): Promise<void> => {
        try {
          const [tzData, geoData] = await Promise.all([
            fetchJson('/tz-index.json'),
            fetchJson('/geo-index.json'),
          ]);
          // Trusted first-party build artifacts (see the *.json.ts endpoints);
          // guard the shape so a future endpoint change fails loudly, not silently.
          if (!Array.isArray(tzData) || !Array.isArray(geoData)) {
            throw new Error('home: index payload is not an array');
          }
          const zones = tzData as ZoneCity[];
          // Always prime the geo index — the 📍 label needs it even if the user
          // has already moved past the timezone estimate below.
          geoIndex = geoData as GeoCity[];
          // Only paint the estimate while still idle: a 📍 fix (or a pre-check
          // denial) that resolved first must not be clobbered by this slower,
          // lower-priority default. The reducer state is the priority guard.
          if (state.status === 'idle' && zones.length > 0) {
            const largest = zones.reduce((a, b) => (b.population > a.population ? b : a));
            const picked = resolveDefaultCity(browserTimeZone(), zones, largest);
            const entry = geoIndex.find((g) => g.slug === picked.slug);
            if (entry) {
              // Real change (different city/value) → crossfade. The step-1
              // same-city recompute above paints directly (nothing visibly
              // changes, so a fade there would just flicker).
              crossfade(() => {
                render(entry.lon, picked.timeZone);
                setEyebrow(entry.name, 'Estimated from your time zone');
              });
            }
          }
        } catch (error) {
          console.warn('home: timezone estimate failed', error);
        }
        // Permissions pre-check: a pre-blocked visitor sees the search hint, not
        // a button that silently does nothing.
        if (state.status === 'idle' && (await checkPermission()) === 'denied') {
          dispatch({ type: 'DENIED' });
        }
      })();

      // 3. 📍 → exact fix from precise coordinates (no city needed for the number).
      const dispatchForError = (error: unknown): void => {
        const kind = error instanceof GeolocationError ? error.kind : 'unavailable';
        if (kind === 'denied') dispatch({ type: 'DENIED' });
        else if (kind === 'timeout') dispatch({ type: 'TIMEOUT' });
        else if (kind === 'unsupported') dispatch({ type: 'UNSUPPORTED' });
        else dispatch({ type: 'UNAVAILABLE' });
      };

      button.addEventListener('click', () => {
        dispatch({ type: 'REQUEST' });
        void getCurrentPosition({ timeoutMs: DEFAULT_TIMEOUT_MS })
          .then(({ lat, lon }) => {
            const nearest = geoIndex ? findNearestCity(lat, lon, geoIndex) : null;
            const label = locatedLabel(nearest);
            // Real change (📍 fix) → crossfade the number/labels in (anim 3, #84).
            crossfade(() => {
              render(lon, browserTimeZone());
              setEyebrow(label.primary, label.near ?? '');
            });
            // Anonymous "geolocation was used" event — deliberately carries NO
            // coordinates (PRD story 29/30); the fix never leaves the browser.
            trackEvent('geolocation_used');
            dispatch({ type: 'SUCCESS', coords: { lat, lon } });
          })
          .catch(dispatchForError);
      });
    };

    // Register once at module scope (the module hoists a single time, so no
    // double-binding); `astro:page-load` fires on the first full load AND on
    // every View-Transition navigation, so `initHome` re-runs on Back/Forward
    // to `/` — the fix for the stale "In sync" (#126).
    document.addEventListener('astro:page-load', initHome);
  </script>

  <style>
    .page {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      /* Symmetric page frame, but a tighter bottom so the gap down to the
         support note / footer joins the --space-section rhythm (fix #83). */
      padding: var(--page-pad-y) var(--page-pad-x) var(--space-section);
    }
    .content {
      width: 100%;
      max-width: var(--content-max);
    }

    /* Live-geo tool — the interactive hero, first thing under the shared header
       (the keyword <h1> lives in the explainer below; the brand tagline is in the
       header). Heading size is not a ranking factor (#82 research), so nothing
       needs to sit above the number. */
    .tool {
      margin-top: 0;
    }

    /* Value crossfade (anim 3, #84) — the resolved-value region dips to
       transparent and back while its contents swap (orchestrated in the island
       above). opacity only, so no layout shift; prefers-reduced-motion disables
       the transition (tokens.css), making the swap instant. */
    .result {
      transition: opacity var(--motion-fast) var(--ease-out);
    }
    .result.is-swapping {
      opacity: 0;
    }

    /* Explainer — the "what is solar time?" <h1> + definition, BELOW the tool
       (fully visible, just lower in the DOM: full SEO weight, no wall above the
       number). Its <h1> is the page's single heading. */
    .explainer {
      margin-top: var(--space-section);
    }
    .intro {
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.6;
      color: var(--muted);
      max-width: 46ch;
      margin: var(--space-sm) auto 0;
      text-align: center;
      text-wrap: pretty;
    }

    /* Shared heading style for the explainer <h1> + directory/FAQ <h2>s. */
    .explainer h1,
    .directory h2,
    .faq h2 {
      font-family: var(--sans);
      font-size: 20px;
      line-height: 1.2;
      color: var(--text);
      text-align: center;
      margin: 0;
    }
    .section-lead {
      font-family: var(--sans);
      font-size: 13px;
      line-height: 1.5;
      color: var(--muted);
      text-align: center;
      max-width: 42ch;
      margin: var(--space-xs) auto 0;
    }

    /* City directory — a flat, crawlable grid of the top-24-by-population links. */
    .directory {
      margin-top: var(--space-section);
    }
    .directory-grid {
      list-style: none;
      padding: 0;
      margin: var(--space-lg) 0 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 2px var(--space-md);
    }
    .directory-grid a {
      display: block;
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      padding: 6px 0;
      transition: color 0.2s;
    }
    .directory-grid a:hover {
      color: var(--accent);
    }

    /* Landing FAQ — always-open Q&A; its copy is the FAQPage JSON-LD's SSOT. */
    .faq {
      margin-top: var(--space-section);
    }
    .faq-list {
      margin: var(--space-lg) 0 0;
    }
    .faq-item + .faq-item {
      margin-top: var(--space-md);
      padding-top: var(--space-md);
      border-top: 1px solid var(--hairline);
    }
    .faq-item dt {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      margin: 0;
    }
    .faq-item dd {
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.6;
      color: var(--muted);
      margin: var(--space-xs) 0 0;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-align: center;
      margin: 0 0 var(--space-lg);
    }
    .eyebrow-note {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--muted-dim);
    }
    .geo {
      margin: var(--space-section) auto 0;
      text-align: center;
    }
    .geo-button {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.04em;
      color: var(--text);
      background: transparent;
      border: 1px solid var(--axis);
      border-radius: 999px;
      padding: 9px 18px;
      cursor: pointer;
      transition:
        border-color 0.2s,
        color 0.2s;
    }
    .geo-button:hover:not(:disabled) {
      border-color: var(--accent);
      color: var(--accent);
    }
    .geo-button:disabled {
      opacity: 0.6;
      cursor: default;
    }
    .geo-hint {
      font-size: 13px;
      line-height: 1.5;
      color: var(--muted);
      max-width: 36ch;
      margin: 0 auto;
    }
    .geo-note {
      font-size: 11px;
      color: var(--muted-dim);
      margin: var(--space-sm) auto 0;
    }
    .geo-note a {
      color: inherit;
      text-decoration: underline;
    }
    .geo-note a:hover {
      color: var(--muted);
    }

    /* Mobile: the primary action + directory links get a full 44px touch target. */
    @media (max-width: 480px) {
      .geo-button {
        min-height: var(--tap-min);
        padding: 9px 20px;
      }
      .directory-grid a {
        display: flex;
        align-items: center;
        min-height: var(--tap-min);
        padding: 0;
      }
    }
  </style>
</Base>
