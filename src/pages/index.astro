 * Placeholder landing page.
 *
 * Trivial page for the skeleton slice — proves the full delivery pipeline
 * (build → CI → Firebase preview/stage deploy) before real UI lands. Carries
 * noindex until the live geo mode (slice #7) replaces it; it reuses `Base` so
 * the site-wide search is present here too.
 */
import Base from '../layouts/Base.astro';
---

<Base title="Solar Time — coming soon" noindex>
