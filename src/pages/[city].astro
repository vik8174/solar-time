---
/**
 * City page — pre-rendered per city via SSG, showing the clock-vs-sun deviation.
 *
 * The build bakes a correct-at-build snapshot; a client inline script recomputes
 * for today's date with the same `computeDeviation` (zero network, no layout
 * shift). Presentation is delegated to HeroNumber / SolarScale / Breakdown.
 */
import type { GetStaticPaths } from 'astro';

import Breakdown from '../components/Breakdown.astro';
import HeroNumber from '../components/HeroNumber.astro';
import SolarScale from '../components/SolarScale.astro';
import { IS_PROD } from '../config/site';
import { CITIES } from '../data/cities';
import { computeDeviation } from '../domain/solarTime';
import Base from '../layouts/Base.astro';
import { buildCityViewModel } from '../lib/cityViewModel';
import { seoMeta } from '../lib/seoMeta';

export const getStaticPaths = (() =>
  CITIES.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }))) satisfies GetStaticPaths;

const { city } = Astro.props;

const deviation = computeDeviation({
  longitude: city.longitude,
  timeZone: city.timeZone,
  date: new Date(),
});
const vm = buildCityViewModel({ name: city.name, coords: city.coords }, deviation);
// SEO/share metadata from the same build-time deviation (D-003). City pages are
// indexable on prod, noindex on stage (D-020).
const meta = seoMeta({ name: city.name, slug: city.slug }, deviation);
---

<Base
  title={meta.title}
  description={meta.description}
  canonicalPath={meta.canonicalPath}
  ogImagePath={meta.ogImagePath}
  noindex={!IS_PROD}
  support
>
  <main
    class="page"
    data-city-slug={city.slug}
    data-city-name={city.name}
    data-city-coords={city.coords}
    data-city-longitude={city.longitude}
    data-city-timezone={city.timeZone}
  >
    <div class="content">
      <p class="eyebrow">{vm.cityName} · {vm.coords}</p>

      <HeroNumber
        heroValue={vm.heroValue}
        showUnit={vm.showUnit}
        leadText={vm.leadText}
        solarNoonText={vm.solarNoonText}
      />

      <SolarScale geometry={vm.geometry} solarNoonLabel={vm.solarNoonLabel} />

      <Breakdown rows={vm.breakdown} />

      <div class="share">
        <button type="button" class="share-button" data-share-button hidden>Share</button>
        <span class="share-status" data-share-status role="status" aria-live="polite"></span>
      </div>
    </div>
  </main>

  <script>
    import { computeDeviation } from '../domain/solarTime';
    import { buildCityViewModel } from '../lib/cityViewModel';
    import { scaleInnerSvg } from '../lib/scaleSvg';

    /**
     * Recompute for today so a page built days ago never shows a stale number.
     * Same domain + view model as the build → identical output, no reflow.
     *
     * The city's data is inlined into `data-*` attributes at build time, so
     * this island never imports the ~1000-city registry (bundle stays tiny —
     * ADR D-013). Only the domain + view-model modules (the SSOT) are pulled.
     */
    const root = document.querySelector<HTMLElement>('[data-city-slug]');
    const longitude = Number(root?.dataset.cityLongitude);
    const timeZone = root?.dataset.cityTimezone;
    const name = root?.dataset.cityName;
    const coords = root?.dataset.cityCoords;
    if (
      root &&
      timeZone &&
      name !== undefined &&
      coords !== undefined &&
      !Number.isNaN(longitude)
    ) {
      const vm = buildCityViewModel(
        { name, coords },
        computeDeviation({ longitude, timeZone, date: new Date() }),
      );

      const setText = (selector: string, text: string): void => {
        const el = document.querySelector(selector);
        if (el) el.textContent = text;
      };

      setText('[data-hero-value]', vm.heroValue);
      setText('[data-lead]', vm.leadText);
      setText('[data-solar-noon]', vm.solarNoonText);
      setText('[data-scale-noon]', vm.solarNoonLabel);

      const unit = document.querySelector<HTMLElement>('[data-hero-unit]');
      if (unit) unit.hidden = !vm.showUnit;
      document.querySelector('.hero')?.classList.toggle('synced', vm.inSync);

      const scale = document.querySelector('[data-scale]');
      if (scale) scale.innerHTML = scaleInnerSvg(vm.geometry);

      for (const row of vm.breakdown) {
        setText(`[data-row-value="${row.key}"]`, row.value);
        document.querySelector(`[data-row="${row.key}"]`)?.classList.toggle('zero', row.zero);
      }
    }
  </script>

  <script>
    import { buildShareUrl, pickShareStrategy } from '../lib/share';

    /**
     * Share adapter (D-001) — a thin wrapper around the pure `pickShareStrategy`
     * / `buildShareUrl` (D-012). Feature-detects the Web Share and Clipboard
     * APIs (never UA-sniffs), then either opens the OS share sheet or copies the
     * clean city URL with a brief "Link copied" confirmation. When neither API
     * exists the button stays hidden — never a dead end.
     *
     * Re-binds on `astro:page-load` because `<main>` is swapped (not persisted)
     * on every View-Transition navigation between city pages, so the fresh
     * button needs the listener re-attached — twin of the support-dismiss adapter.
     */
    const CONFIRM_MS = 2000;

    const initShare = (): void => {
      const root = document.querySelector<HTMLElement>('[data-city-slug]');
      const button = document.querySelector<HTMLButtonElement>('[data-share-button]');
      const status = document.querySelector<HTMLElement>('[data-share-status]');
      const slug = root?.dataset.citySlug;
      if (!button || !status || slug === undefined) return;

      const strategy = pickShareStrategy({
        canShare: typeof navigator.share === 'function',
        canClipboard: typeof navigator.clipboard?.writeText === 'function',
      });

      // No usable API → leave the button hidden (graceful degradation).
      if (strategy === 'none') return;

      const url = buildShareUrl(slug, window.location.origin);
      button.textContent = strategy === 'native' ? 'Share' : 'Copy link';
      button.hidden = false;

      let confirmTimer: ReturnType<typeof setTimeout> | undefined;
      const flash = (message: string): void => {
        status.textContent = message;
        if (confirmTimer !== undefined) clearTimeout(confirmTimer);
        confirmTimer = setTimeout(() => {
          status.textContent = '';
        }, CONFIRM_MS);
      };

      const copyLink = (): void => {
        void navigator.clipboard.writeText(url).then(
          () => flash('Link copied'),
          (error: unknown) => {
            // A real clipboard failure — surface it visibly and log it.
            console.warn('share: clipboard write failed', error);
            flash('Copy failed');
          },
        );
      };

      button.addEventListener('click', () => {
        if (strategy === 'native') {
          void navigator.share({ title: document.title, url }).catch((error: unknown) => {
            // User cancelled the OS sheet — swallow that one case intentionally.
            if (error instanceof DOMException && error.name === 'AbortError') return;
            console.warn('share: native share failed', error);
          });
        } else {
          copyLink();
        }
      });
    };

    document.addEventListener('astro:page-load', initShare);
  </script>

  <style>
    .page {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: var(--page-pad-y) var(--page-pad-x);
    }
    .content {
      width: 100%;
      max-width: var(--content-max);
    }
    .eyebrow {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-align: center;
      margin: 0 0 24px;
    }
    .share {
      margin: 36px auto 0;
      text-align: center;
    }
    .share-button {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.04em;
      color: var(--text);
      background: transparent;
      border: 1px solid var(--axis);
      border-radius: 999px;
      padding: 9px 18px;
      cursor: pointer;
      transition:
        border-color 0.2s,
        color 0.2s;
    }
    .share-button:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
    .share-status {
      display: block;
      margin-top: 12px;
      min-height: 1em;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--muted);
    }

    /* Mobile: the share action gets a full 44px touch target. */
    @media (max-width: 480px) {
      .share-button {
        min-height: var(--tap-min);
        padding: 9px 20px;
      }
    }
  </style>
</Base>
