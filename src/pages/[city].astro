---
/**
 * City page — pre-rendered per city via SSG, showing the clock-vs-sun deviation.
 *
 * The build bakes a correct-at-build snapshot; a client inline script recomputes
 * for today's date with the same `computeDeviation` (zero network, no layout
 * shift). Presentation is delegated to HeroNumber / SolarScale / Breakdown.
 */
import type { GetStaticPaths } from 'astro';

import Breakdown from '../components/Breakdown.astro';
import HeroNumber from '../components/HeroNumber.astro';
import SolarScale from '../components/SolarScale.astro';
import { IS_PROD } from '../config/site';
import { CITIES } from '../data/cities';
import { computeDeviation } from '../domain/solarTime';
import Base from '../layouts/Base.astro';
import { buildCityViewModel } from '../lib/cityViewModel';
import { seoMeta } from '../lib/seoMeta';

export const getStaticPaths = (() =>
  CITIES.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }))) satisfies GetStaticPaths;

const { city } = Astro.props;

const deviation = computeDeviation({
  longitude: city.longitude,
  timeZone: city.timeZone,
  date: new Date(),
});
const vm = buildCityViewModel({ name: city.name, coords: city.coords }, deviation);
// SEO/share metadata from the same build-time deviation (D-003). City pages are
// indexable on prod, noindex on stage (D-019).
const meta = seoMeta({ name: city.name, slug: city.slug }, deviation);
---

<Base
  title={meta.title}
  description={meta.description}
  canonicalPath={meta.canonicalPath}
  ogImagePath={meta.ogImagePath}
  noindex={!IS_PROD}
  support
>
  <main
    class="page"
    data-city-slug={city.slug}
    data-city-name={city.name}
    data-city-coords={city.coords}
    data-city-longitude={city.longitude}
    data-city-timezone={city.timeZone}
  >
    <div class="content">
      <p class="eyebrow">{vm.cityName} · {vm.coords}</p>

      <HeroNumber
        heroValue={vm.heroValue}
        showUnit={vm.showUnit}
        leadText={vm.leadText}
        solarNoonText={vm.solarNoonText}
      />

      <SolarScale geometry={vm.geometry} solarNoonLabel={vm.solarNoonLabel} />

      <Breakdown rows={vm.breakdown} />
    </div>
  </main>

  <script>
    import { computeDeviation } from '../domain/solarTime';
    import { buildCityViewModel } from '../lib/cityViewModel';
    import { scaleInnerSvg } from '../lib/scaleSvg';

    /**
     * Recompute for today so a page built days ago never shows a stale number.
     * Same domain + view model as the build → identical output, no reflow.
     *
     * The city's data is inlined into `data-*` attributes at build time, so
     * this island never imports the ~1000-city registry (bundle stays tiny —
     * ADR D-013). Only the domain + view-model modules (the SSOT) are pulled.
     */
    const root = document.querySelector<HTMLElement>('[data-city-slug]');
    const longitude = Number(root?.dataset.cityLongitude);
    const timeZone = root?.dataset.cityTimezone;
    const name = root?.dataset.cityName;
    const coords = root?.dataset.cityCoords;
    if (
      root &&
      timeZone &&
      name !== undefined &&
      coords !== undefined &&
      !Number.isNaN(longitude)
    ) {
      const vm = buildCityViewModel(
        { name, coords },
        computeDeviation({ longitude, timeZone, date: new Date() }),
      );

      const setText = (selector: string, text: string): void => {
        const el = document.querySelector(selector);
        if (el) el.textContent = text;
      };

      setText('[data-hero-value]', vm.heroValue);
      setText('[data-lead]', vm.leadText);
      setText('[data-solar-noon]', vm.solarNoonText);
      setText('[data-scale-noon]', vm.solarNoonLabel);

      const unit = document.querySelector<HTMLElement>('[data-hero-unit]');
      if (unit) unit.hidden = !vm.showUnit;
      document.querySelector('.hero')?.classList.toggle('synced', vm.inSync);

      const scale = document.querySelector('[data-scale]');
      if (scale) scale.innerHTML = scaleInnerSvg(vm.geometry);

      for (const row of vm.breakdown) {
        setText(`[data-row-value="${row.key}"]`, row.value);
        document.querySelector(`[data-row="${row.key}"]`)?.classList.toggle('zero', row.zero);
      }
    }
  </script>

  <style>
    .page {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 40px 20px 40px;
    }
    .content {
      width: 100%;
      max-width: 480px;
    }
    .eyebrow {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-align: center;
      margin: 0 0 24px;
    }
  </style>
</Base>
