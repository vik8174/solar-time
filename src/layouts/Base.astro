---
/**
 * Base — the shared page shell (slice #6).
 *
 * Owns the `<head>`, the design tokens, and the site-wide `CitySearch` island so
 * search lives in exactly one place across every page. `<ClientRouter />` adds
 * View Transitions (smooth `/${slug}` navigation + hover-prefetch of results);
 * the header is `transition:persist`ed so the search box and its already-built
 * index survive navigations instead of re-hydrating each time.
 *
 * @example
 * <Base title="Solar time in Prague">…page…</Base>
 */
import { ClientRouter } from 'astro:transitions';

import CitySearch from '../components/CitySearch.tsx';
import '../styles/tokens.css';

interface Props {
  /** Document title (also og:title / twitter:title). */
  title: string;
  /** Meta description (also og:description / twitter:description). */
  description?: string;
  /** Site-relative canonical path, e.g. `/prague`; absolutized against `site`. */
  canonicalPath?: string;
  /** Site-relative OG image path, e.g. `/og/prague.png`; absolutized against `site`. */
  ogImagePath?: string;
  /** Emit `<meta name="robots" content="noindex">` (e.g. the live home page). */
  noindex?: boolean;
}

const { title, description, canonicalPath, ogImagePath, noindex = false } = Astro.props;

// Absolutize the site-relative paths against `site` (set per build target in
// astro.config, D-020). Guarded so the tags drop cleanly if `site` is unset.
const site = Astro.site;
const canonical = canonicalPath && site ? new URL(canonicalPath, site).href : undefined;
const ogImage = ogImagePath && site ? new URL(ogImagePath, site).href : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solar Time" />
    {canonical && <meta property="og:url" content={canonical} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content={title} />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <ClientRouter />
  </head>
  <body>
    <header class="site-header" transition:persist>
      <CitySearch client:idle />
    </header>
    <slot />
  </body>
</html>

<style>
  .site-header {
    padding: 16px 20px 0;
  }
</style>
