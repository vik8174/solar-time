---
/**
 * Base — the shared page shell (slice #6).
 *
 * Owns the `<head>`, the design tokens, and the site-wide `CitySearch` island so
 * search lives in exactly one place across every page. `<ClientRouter />` adds
 * View Transitions (smooth `/${slug}` navigation + hover-prefetch of results);
 * the header is `transition:persist`ed so the search box and its already-built
 * index survive navigations instead of re-hydrating each time.
 *
 * @example
 * <Base title="Solar time in Prague">…page…</Base>
 */
import { ClientRouter } from 'astro:transitions';

import CitySearch from '../components/CitySearch.tsx';
import { FEEDBACK_URL, GEONAMES_URL, GITHUB_URL, SUPPORT_URL } from '../config/links';
import '../styles/tokens.css';

interface Props {
  /** Document title (also og:title / twitter:title). */
  title: string;
  /** Meta description (also og:description / twitter:description). */
  description?: string;
  /** Site-relative canonical path, e.g. `/prague`; absolutized against `site`. */
  canonicalPath?: string;
  /** Site-relative OG image path, e.g. `/og/prague.png`; absolutized against `site`. */
  ogImagePath?: string;
  /** Emit `<meta name="robots" content="noindex">` (e.g. the live home page). */
  noindex?: boolean;
  /**
   * Render the quiet, dismissable Buy-Me-a-Coffee note after the result. Set on
   * the result pages (`/`, `/[city]`); omitted on `/privacy` (D-008).
   */
  support?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  ogImagePath,
  noindex = false,
  support = false,
} = Astro.props;

// Absolutize the site-relative paths against `site` (set per build target in
// astro.config, D-020). Guarded so the tags drop cleanly if `site` is unset.
const site = Astro.site;
const canonical = canonicalPath && site ? new URL(canonicalPath, site).href : undefined;
const ogImage = ogImagePath && site ? new URL(ogImagePath, site).href : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solar Time" />
    {canonical && <meta property="og:url" content={canonical} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content={title} />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <ClientRouter />
  </head>
  <body>
    <header class="site-header" transition:persist>
      <CitySearch client:idle />
    </header>
    <slot />

    {
      support && (
        <aside class="support" data-support hidden>
          <p class="support-note">
            Found this useful?
            <a href={SUPPORT_URL} target="_blank" rel="noopener noreferrer">
              Buy me a coffee ☕
            </a>
          </p>
          <button
            type="button"
            class="support-dismiss"
            data-support-dismiss
            aria-label="Dismiss support note"
          >
            ×
          </button>
        </aside>
      )
    }

    <footer class="site-footer">
      <nav class="footer-links" aria-label="Site">
        <a href="/privacy">Privacy</a>
        <a href={FEEDBACK_URL} target="_blank" rel="noopener noreferrer">Feedback</a>
        <a href={SUPPORT_URL} target="_blank" rel="noopener noreferrer">Support</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>
      <p class="footer-credit">
        City data © <a href={GEONAMES_URL} target="_blank" rel="noopener noreferrer">GeoNames</a> (CC
        BY 4.0)
      </p>
    </footer>
  </body>
</html>

<script>
  import { SUPPORT_DISMISSED, shouldShowSupport } from '../lib/supportVisibility';

  /**
   * Thin adapter around the pure `shouldShowSupport` (D-012): read the stored
   * flag, reveal the note when it should show, and persist a dismissal. Runs on
   * `astro:page-load` so it re-binds after each View Transition navigation.
   */
  const KEY = 'solar-time:support-dismissed';

  const readFlag = (): string | null => {
    try {
      return localStorage.getItem(KEY);
    } catch (error) {
      // Storage blocked (private mode / disabled) — fail open, show the note.
      console.warn('support: reading dismiss flag failed', error);
      return null;
    }
  };

  const initSupport = (): void => {
    const note = document.querySelector<HTMLElement>('[data-support]');
    const dismiss = document.querySelector<HTMLButtonElement>('[data-support-dismiss]');
    if (!note || !dismiss) return;

    note.hidden = !shouldShowSupport(readFlag());

    dismiss.addEventListener('click', () => {
      try {
        localStorage.setItem(KEY, SUPPORT_DISMISSED);
      } catch (error) {
        // Can't persist — still hide it for this session.
        console.warn('support: persisting dismissal failed', error);
      }
      note.hidden = true;
    });
  };

  document.addEventListener('astro:page-load', initSupport);
</script>

<style>
  .site-header {
    padding: 16px 20px 0;
  }

  .support {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 auto 8px;
    padding: 0 20px;
    text-align: center;
  }
  .support-note {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
  }
  .support-note a {
    color: var(--accent);
    text-decoration: none;
  }
  .support-note a:hover {
    text-decoration: underline;
  }
  .support-dismiss {
    flex: none;
    width: 22px;
    height: 22px;
    padding: 0;
    font-size: 16px;
    line-height: 1;
    color: var(--muted-dim);
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .support-dismiss:hover {
    color: var(--muted);
  }

  .site-footer {
    padding: 24px 20px 32px;
    text-align: center;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 16px;
  }
  .footer-links a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--accent);
  }
  .footer-credit {
    margin: 12px 0 0;
    font-size: 11px;
    color: var(--muted-dim);
  }
  .footer-credit a {
    color: inherit;
  }
  .footer-credit a:hover {
    color: var(--muted);
  }
</style>
