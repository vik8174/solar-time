---
/**
 * Base — the shared page shell (slice #6).
 *
 * Owns the `<head>`, the design tokens, and the site-wide `CitySearch` island so
 * search lives in exactly one place across every page. `<ClientRouter />` adds
 * View Transitions (smooth `/${slug}` navigation + hover-prefetch of results);
 * the header is `transition:persist`ed so the search box and its already-built
 * index survive navigations instead of re-hydrating each time.
 *
 * @example
 * <Base title="Solar time in Prague">…page…</Base>
 */
import { ClientRouter } from 'astro:transitions';

import CitySearch from '../components/CitySearch.tsx';
import { FEEDBACK_URL, GEONAMES_URL, SUPPORT_URL } from '../config/links';
import { ANALYTICS_ENV } from '../config/site';
import { BRAND_TILE, brandMarkSvg } from '../lib/brandMark';
import { serializeJsonLd, type JsonLdNode } from '../lib/jsonLd';
import '../styles/tokens.css';

// The brand badge, shared with the favicon set (#89) so the mark is one identity
// everywhere. Decorative in the header — the wordmark is the accessible link text.
const brandMark = brandMarkSvg();

interface Props {
  /** Document title (also og:title / twitter:title). */
  title: string;
  /** Meta description (also og:description / twitter:description). */
  description?: string;
  /** Site-relative canonical path, e.g. `/prague`; absolutized against `site`. */
  canonicalPath?: string;
  /** Site-relative OG image path, e.g. `/og/prague.png`; absolutized against `site`. */
  ogImagePath?: string;
  /** Emit `<meta name="robots" content="noindex">` (e.g. the live home page). */
  noindex?: boolean;
  /**
   * Builds the page's JSON-LD from the absolute site origin (#86). A builder,
   * not a value, because the nodes embed absolute URLs: it is called only when
   * `Astro.site` is set, so the `<script>` drops cleanly when it is not —
   * never a relative or `undefined` URL. See `src/lib/jsonLd.ts`.
   */
  jsonLd?: (origin: string) => JsonLdNode | readonly JsonLdNode[];
  /**
   * Render the quiet Buy-Me-a-Coffee note after the result. Set on the result
   * pages (`/`, `/[city]`); omitted on `/privacy` (D-008).
   */
  support?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  ogImagePath,
  noindex = false,
  support = false,
  jsonLd,
} = Astro.props;

// Absolutize the site-relative paths against `site` (set per build target in
// astro.config, D-020). Guarded so the tags drop cleanly if `site` is unset —
// the JSON-LD builder runs under the same guard, for the same reason.
const site = Astro.site;
const canonical = canonicalPath && site ? new URL(canonicalPath, site).href : undefined;
const ogImage = ogImagePath && site ? new URL(ogImagePath, site).href : undefined;
const structuredData = jsonLd && site ? jsonLd(site.href) : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content={BRAND_TILE} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solar Drift" />
    {canonical && <meta property="og:url" content={canonical} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content={title} />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {
      /* `set:html` because Astro HTML-escapes text children, which would turn
         `&` into `&amp;` and corrupt the JSON. `is:inline` keeps Astro from
         treating it as a bundleable script. Serializer escapes `<`. */
      structuredData && (
        <script type="application/ld+json" is:inline set:html={serializeJsonLd(structuredData)} />
      )
    }
    <ClientRouter />
  </head>
  <body data-analytics-env={ANALYTICS_ENV}>
    <header class="site-header" transition:persist>
      <a
        class="site-wordmark"
        href="/"
        aria-current={Astro.url.pathname === '/' ? 'page' : undefined}
      >
        <span class="brand-mark" aria-hidden="true" set:html={brandMark} />
        Solar Drift
      </a>
      <CitySearch client:idle />
    </header>
    <slot />

    {
      support && (
        <aside class="support">
          <p class="support-note">
            Found this useful?{' '}
            <a href={SUPPORT_URL} target="_blank" rel="noopener noreferrer">
              Buy me a coffee ☕
            </a>
          </p>
        </aside>
      )
    }

    <footer class="site-footer">
      <nav class="footer-links" aria-label="Site">
        <a href="/privacy">Privacy</a>
        <a href={FEEDBACK_URL} target="_blank" rel="noopener noreferrer">Feedback</a>
        <a href={SUPPORT_URL} target="_blank" rel="noopener noreferrer">Support</a>
      </nav>
      <p class="footer-credit">
        City data © <a href={GEONAMES_URL} target="_blank" rel="noopener noreferrer">GeoNames</a> (CC
        BY 4.0)
      </p>
    </footer>
  </body>
</html>

<script>
  import { startDeferredInit, trackEvent } from '../scripts/deferredInit';

  /**
   * Analytics + error-monitoring mount (D-008, D-021). Runs once per full load
   * (Astro hoists module scripts, so it survives View Transitions): boot both
   * SDKs after idle via `deferredInit`, then emit an anonymous `page_view` on
   * the initial load and after every navigation. The environment tag is baked
   * into `data-analytics-env` at build time (D-020); the SDK keys reach the
   * client through `import.meta.env.PUBLIC_*` inside `deferredInit`.
   */
  const environment = document.body.dataset.analyticsEnv ?? 'staging';
  startDeferredInit(environment);

  document.addEventListener('astro:page-load', () => {
    trackEvent('page_view', { path: window.location.pathname });
  });
</script>

<style>
  .site-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-md) var(--page-pad-x) 0;
  }
  /*
   * Home-linking brand wordmark (nav link, not a heading — the home hero owns
   * the <h1>). inline-flex so only the text is the click target (no dead
   * whitespace nav); centered by the header column to match the site's rhythm.
   * Gap to the search uses the #83 spacing scale, not a magic number.
   */
  .site-wordmark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--space-sm);
    font-family: var(--mono);
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--text);
    text-decoration: none;
  }
  .site-wordmark:hover {
    color: var(--accent);
  }
  /*
   * The brand badge (#89) — same sundial-on-tile SVG as the favicon, so the mark
   * is one identity across tab, header and OG. Decorative (aria-hidden); the
   * wordmark text is the link's accessible name. Fixed 20px reads as an icon
   * beside the 15px mono wordmark and doesn't disturb the #80 375px layout.
   */
  .brand-mark {
    display: inline-flex;
    flex: none;
  }
  .brand-mark :global(svg) {
    display: block;
    width: 20px;
    height: 20px;
  }

  .support {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 auto var(--space-xs);
    padding: 0 var(--page-pad-x);
    text-align: center;
  }
  .support-note {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
  }
  .support-note a {
    color: var(--accent);
    text-decoration: none;
  }
  .support-note a:hover {
    text-decoration: underline;
  }

  .site-footer {
    padding: var(--space-md) var(--page-pad-x) var(--space-xl);
    text-align: center;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 16px;
  }
  .footer-links a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--accent);
  }

  /* Mobile: give the wordmark and footer links a real touch area. */
  @media (max-width: 480px) {
    .site-wordmark {
      min-height: var(--tap-min);
    }
    .footer-links {
      gap: 6px 12px;
    }
    .footer-links a {
      display: inline-flex;
      align-items: center;
      min-height: var(--tap-min);
      padding: 0 8px;
    }
  }
  .footer-credit {
    margin: var(--space-sm) 0 0;
    font-size: 11px;
    color: var(--muted-dim);
  }
  .footer-credit a {
    color: inherit;
  }
  .footer-credit a:hover {
    color: var(--muted);
  }
</style>
