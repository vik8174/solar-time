{
  "name": "solar-time",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "test -z \"$CI\" && git config core.hooksPath .githooks || true",
    "dev": "astro dev",
    "build": "astro build",
    "build:cities": "tsx scripts/buildCities.ts",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy:stage": "npm run build && firebase deploy --only hosting -P stage",
    "deploy:prod": "SITE_ENV=prod npm run build && firebase deploy --only hosting -P prod"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@astrojs/sitemap": "3.7.3",
    "@resvg/resvg-js": "2.6.2",
    "astro": "7.0.6",
    "fuse.js": "7.4.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "satori": "0.26.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "astro-eslint-parser": "1.4.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "1.7.0",
    "firebase-tools": "15.22.4",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  }
}
