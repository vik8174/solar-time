# build output
dist/
# generated types
.astro/
# buildCities dump cache (regenerated from GeoNames on demand)
scripts/.cache/

# firebase deploy cache
.firebase/
firebase-debug.log*
coverage/

# dependencies
# No trailing slash: also ignores the `node_modules` *symlink* that
# scripts/ticket-worktree.sh creates in per-ticket worktrees (a symlink is a
# file, so a `node_modules/` dir-only pattern would leave it untracked).
node_modules

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# coordinator handoffs — temporary, not part of git history (keep only the README)
/handoffs/*
!/handoffs/README.md
